    "@quant/common": "workspace:*",
    "zod": "^3.24.2",
    "pino": "^9.6.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "vitest": "^4",
    "typescript": "~5.5.0",
    "ts-node": "^10.9.0"
  }
