{
  "name": "@quant/moderation-worker",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "main": "src/main.ts",
  "scripts": {
    "start": "node --loader ts-node/esm src/main.ts",
    "dev": "node --loader ts-node/esm --watch src/main.ts",
