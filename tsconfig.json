{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "composite": true,
    "incremental": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,
    "noUncheckedIndexedAccess": true,
    "noImplicitOverride": true,
    "exactOptionalPropertyTypes": false,
    "jsx": "react-jsx",
    "baseUrl": ".",
    "paths": {
      "@quant/common": ["packages/common/src/index.ts"],
      "@quant/common/*": ["packages/common/src/*"],
      "@quant/database": ["packages/database/src/index.ts"],
      "@quant/database/*": ["packages/database/src/*"],
      "@quant/auth": ["packages/auth/src/index.ts"],
      "@quant/auth/*": ["packages/auth/src/*"],
      "@quant/ai": ["packages/ai/src/index.ts"],
      "@quant/ai/*": ["packages/ai/src/*"],
      "@quant/shared-ui": ["packages/shared-ui/src/index.ts"],
      "@quant/shared-ui/*": ["packages/shared-ui/src/*"],
      "@quant/realtime": ["packages/realtime/src/index.ts"],
      "@quant/realtime/*": ["packages/realtime/src/*"],
      "@quant/server": ["packages/server/src/index.ts"],
      "@quant/server/*": ["packages/server/src/*"],
      "@quant/server-core": ["packages/server-core/src/index.ts"],
      "@quant/server-core/*": ["packages/server-core/src/*"],
      "@quant/api-client": ["packages/api-client/src/index.ts"],
      "@quant/api-client/*": ["packages/api-client/src/*"],
      "@quant/data-plane": ["packages/data-plane/src/index.ts"],
      "@quant/data-plane/*": ["packages/data-plane/src/*"],
      "@quant/queue": ["packages/queue/src/index.ts"],
      "@quant/queue/*": ["packages/queue/src/*"],
      "@quant/storage": ["packages/storage/src/index.ts"],
      "@quant/storage/*": ["packages/storage/src/*"],
      "@quant/agent-runtime": ["packages/agent-runtime/src/index.ts"],
      "@quant/agent-runtime/*": ["packages/agent-runtime/src/*"],
      "@quant/cross-publish": ["packages/cross-publish/src/index.ts"],
      "@quant/cross-publish/*": ["packages/cross-publish/src/*"],
      "@quant/identity-permissions": ["packages/identity-permissions/src/index.ts"],
      "@quant/identity-permissions/*": ["packages/identity-permissions/src/*"],
      "@quant/brand": ["packages/brand/src/index.ts"],
      "@quant/brand/*": ["packages/brand/src/*"]
    }
  },
  "references": [
    { "path": "packages/common" },
    { "path": "packages/database" },
    { "path": "packages/auth" },
    { "path": "packages/ai" },
    { "path": "packages/shared-ui" },
    { "path": "packages/realtime" },
    { "path": "packages/server" },
    { "path": "packages/server-core" },
    { "path": "packages/api-client" },
    { "path": "packages/data-plane" },
    { "path": "packages/queue" },
    { "path": "packages/storage" },
    { "path": "packages/agent-runtime" },
    { "path": "packages/cross-publish" },
    { "path": "packages/identity-permissions" },
    { "path": "packages/brand" }
  ],
  "exclude": ["node_modules", "dist", "build"]
}
