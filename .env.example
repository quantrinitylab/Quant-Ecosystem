# Database
DATABASE_URL=postgresql://quant:quant@localhost:5432/quantdb

# Redis
REDIS_URL=redis://localhost:6379

# Object Storage (S3-compatible)
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=quant-uploads

# Email (MailHog for development)
SMTP_HOST=localhost
SMTP_PORT=1025

# Search
MEILISEARCH_URL=http://localhost:7700
MEILISEARCH_KEY=masterKey

# Event Streaming
NATS_URL=nats://localhost:4222

# Auth
JWT_SECRET=development-only-change-in-production
JWT_ISSUER=https://auth.quant-ecosystem.dev

# AI (optional for development)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Live memory/extraction evals (all optional; tests skip when unset)
# Any OpenAI-compatible /chat/completions gateway works (OpenAI, or the
# Bedrock OpenAI-compatible endpoint). NEVER commit real values.
EXTRACTION_API_KEY=
EXTRACTION_BASE_URL=
EXTRACTION_MODEL=
AWS_BEARER_TOKEN_BEDROCK=
BEDROCK_REGION=
BEDROCK_EMBEDDING_MODEL=
QDRANT_URL=
