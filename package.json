{
  "name": "quant-ecosystem",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "Quant Ecosystem - A 9-app interconnected platform",
  "packageManager": "pnpm@10.28.1",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "lint": "turbo lint",
    "typecheck": "turbo typecheck",
    "test": "turbo test",
    "build": "turbo build",
    "build:ci": "turbo build --concurrency=3",
    "build:cold": "rm -rf .turbo node_modules/.cache && turbo build --concurrency=3",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "validate": "pnpm install --frozen-lockfile && pnpm typecheck && pnpm test && pnpm build && pnpm lint",
    "validate:fast": "turbo typecheck test lint --filter=...[HEAD~1]",
    "prepare": "husky",
    "dev:infra": "docker compose -f docker-compose.dev.yml up -d",
    "dev:core": "turbo dev --filter=@quant/quantmail --filter=@quant/quantchat --filter=@quant/quantai",
    "dev:apps": "turbo dev",
    "dev:all": "pnpm dev:infra && turbo dev",
    "doctor": "tsx scripts/doctor.ts",
    "env:check": "tsx scripts/env-check.ts",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down",
    "db:migrate": "pnpm --filter @quant/database exec prisma migrate deploy",
    "db:seed": "pnpm --filter @quant/database exec prisma db seed",
    "db:reset": "tsx scripts/db-reset.ts",
    "smoke": "tsx scripts/smoke.ts",
    "test:e2e": "playwright test",
    "test:e2e:ci": "playwright test --shard=$CI_SHARD",
    "test:a11y": "playwright test --project=chromium e2e/tests/a11y/",
    "lint:strict": "turbo lint -- --max-warnings 0",
    "validate:routes": "tsx scripts/validate-routes.ts",
    "wiring:dod": "tsx scripts/evaluate-wiring-dod.ts",
    "guard:inline-fetch": "tsx scripts/check-inline-fetch.ts",
    "memory:validate": "tsx scripts/validate-project-memory.ts",
    "test:memory": "vitest run scripts/__tests__/validate-project-memory.test.ts",
    "m11d:wu4": "tsx scripts/m11d-wu4-quantai-shadow.ts",
    "m11d:wu5:release-gate": "tsx scripts/m11d-wu5-release-gate.ts",
    "test:wu5:policy": "vitest run scripts/__tests__/m11d-wu5-release-gate.test.ts",
    "ci:gates": "turbo typecheck && turbo lint -- --max-warnings 0 && turbo test && turbo build"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@prisma/client",
      "@prisma/engines",
      "argon2",
      "esbuild",
      "prisma",
      "sharp"
    ],
    "overrides": {
      "@types/react": "^19.0.0",
      "@types/react-dom": "^19.0.0",
      "esbuild": ">=0.28.1",
      "vite": "^6.4.3",
      "postcss": ">=8.5.10",
      "uuid": ">=11.1.1",
      "tar": ">=7.5.11",
      "form-data": "^4.0.6"
    }
  },
  "devDependencies": {
    "@commitlint/cli": "^19",
    "@commitlint/config-conventional": "^19",
    "@faker-js/faker": "^9",
    "@types/node": "^22.10.1",
    "@typescript-eslint/eslint-plugin": "^8",
    "@typescript-eslint/parser": "^8",
    "@vitest/coverage-v8": "^4",
    "esbuild": "0.24.2",
    "eslint": "^9",
    "husky": "^9",
    "lint-staged": "^15",
    "prettier": "^3",
    "tsx": "^4",
    "turbo": "^2",
    "typescript": "~5.5.0",
    "typescript-eslint": "^8",
    "vitest": "^4"
  }
}
