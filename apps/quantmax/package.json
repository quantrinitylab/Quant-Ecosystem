{
  "name": "@quant/quantmax",
  "version": "1.0.0",
  "private": true,
  "description": "QuantMax - Short video social, random video chat, and dating platform hybrid",
  "main": "backend/app.ts",
  "scripts": {
    "dev": "next dev",
    "dev:backend": "node --loader ts-node/esm backend/app.ts",
    "build": "next build",
    "build:backend": "tsc --noEmit -p tsconfig.backend.json",
    "start": "next start",
    "typecheck": "tsc --noEmit && tsc --noEmit -p tsconfig.backend.json",
    "test": "vitest run",
    "lint": "eslint ."
  },
  "dependencies": {
    "@quant/auth": "workspace:*",
    "@quant/ai": "workspace:*",
    "@quant/brand": "workspace:*",
    "@quant/common": "workspace:*",
    "@quant/database": "workspace:*",
    "@quant/realtime": "workspace:*",
    "@quant/server-core": "workspace:*",
    "@quant/shared-ui": "workspace:*",
    "fastify": "^5.3.3",
    "framer-motion": "^11.0.0",
    "livekit-server-sdk": "^2.15.3",
    "ioredis": "^5.6.1",
    "next": "^15.5.16",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-virtuoso": "^4.0.0",
    "@tanstack/react-query": "^5.60.0",
    "zod": "^3.25.23"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.47",
    "tailwindcss": "^3.4.13",
    "vitest": "^2"
  }
