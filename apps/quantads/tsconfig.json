{
  "compilerOptions": {
    "target": "ES2017",
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "preserve",
    "incremental": true,
    "plugins": [{ "name": "next" }],
    "paths": {
      "@/*": ["./src/app/*"],
      "@quant/shared-ui": ["../../packages/shared-ui/src/index.ts"],
      "@quant/shared-ui/*": ["../../packages/shared-ui/src/*"],
      "@quant/common": ["../../packages/common/src/index.ts"],
      "@quant/common/*": ["../../packages/common/src/*"],
      "@quant/brand": ["../../packages/brand/src/index.ts"],
      "@quant/brand/*": ["../../packages/brand/src/*"],
      "@quant/privacy-ads": ["../../packages/privacy-ads/src/index.ts"],
      "@quant/privacy-ads/*": ["../../packages/privacy-ads/src/*"],
      "@quant/api-client": ["../../packages/api-client/src/index.ts"],
      "@quant/api-client/*": ["../../packages/api-client/src/*"]
    }
  },
  "include": [
    "next-env.d.ts",
    "src/**/*.ts",
    "src/**/*.tsx",
    "backend/**/*.ts",
    ".next/types/**/*.ts"
  ],
  "exclude": ["node_modules"],
  "references": [
    { "path": "../../packages/auth" },
    { "path": "../../packages/ai" },
    { "path": "../../packages/common" },
    { "path": "../../packages/database" },
    { "path": "../../packages/realtime" },
    { "path": "../../packages/server-core" },
    { "path": "../../packages/shared-ui" },
    { "path": "../../packages/privacy-ads" },
    { "path": "../../packages/brand" },
    { "path": "../../packages/api-client" }
  ]
}
