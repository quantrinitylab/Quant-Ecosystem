{
  "name": "@quant/quantmail",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "QuantMail - Central authentication, email, and code management hub for the Quant Ecosystem",
  "main": "backend/app.ts",
  "scripts": {
    "dev": "next dev",
    "dev:backend": "node --loader ts-node/esm backend/app.ts",
    "worker": "tsx backend/worker.ts",
    "build": "next build",
    "build:backend": "tsc --noEmit -p tsconfig.backend.json",
    "start": "next start",
    "typecheck": "tsc --noEmit && tsc --noEmit -p tsconfig.backend.json",
    "test": "vitest run",
    "lint": "eslint ."
  },
  "dependencies": {
    "@quant/api-client": "workspace:*",
    "@prisma/client": "^6.19.3",
    "@quant/ai": "workspace:*",
    "@quant/auth": "workspace:*",
    "@quant/brand": "workspace:*",
    "@quant/common": "workspace:*",
    "@quant/credits": "workspace:*",
    "@quant/database": "workspace:*",
    "@quant/encryption": "workspace:*",
    "@quant/federation": "workspace:*",
    "@quant/notifications": "workspace:*",
    "@quant/queue": "workspace:*",
    "@quant/realtime": "workspace:*",
    "@quant/server-core": "workspace:*",
    "@quant/shared-ui": "workspace:*",
    "@tanstack/react-query": "^5.60.0",
    "argon2": "^0.43.0",
    "@aws-sdk/client-sesv2": "^3.700.0",
    "fastify": "^5.2.1",
    "framer-motion": "^11.0.0",
    "ioredis": "^5.6.1",
    "jose": "^6.0.11",
    "next": "^15.5.16",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "autoprefixer": "^10.4.20",
    "fast-check": "^3.23.2",
    "postcss": "^8.4.47",
    "tailwindcss": "^3.4.13",
    "tsx": "^4",
    "vitest": "^4"
  }
}
