{
  "name": "@quant/quantai",
  "version": "1.0.0",
  "private": true,
  "description": "QuantAI - Central AI hub controlling all ecosystem AI, device automation, and workflow orchestration",
  "main": "backend/app.ts",
  "scripts": {
    "dev": "next dev",
    "dev:backend": "node --loader ts-node/esm backend/app.ts",
    "build": "next build",
    "build:backend": "tsc --noEmit -p tsconfig.backend.json",
    "start": "next start",
    "typecheck": "tsc --noEmit && tsc --noEmit -p tsconfig.backend.json",
    "test": "vitest run",
    "lint": "eslint ."
  },
  "dependencies": {
