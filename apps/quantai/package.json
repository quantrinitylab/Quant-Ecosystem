    "@quant/ai-memory": "workspace:*",
    "@quant/browser-agent": "workspace:*",
    "@quant/code-agent": "workspace:*",
    "@quant/quant-tools": "workspace:*",
    "@quant/user-owned-ai": "workspace:*",
    "@quant/auth": "workspace:*",
    "@quant/ai": "workspace:*",
    "@quant/api-client": "workspace:*",
    "@quant/brand": "workspace:*",
    "@quant/common": "workspace:*",
    "@quant/database": "workspace:*",
    "@quant/realtime": "workspace:*",
    "@quant/server-core": "workspace:*",
    "@quant/shared-ui": "workspace:*",
    "@quant/ab-testing": "workspace:*",
    "@quant/agentic": "workspace:*",
    "@quant/cache": "workspace:*",
