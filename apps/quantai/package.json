    "next": "^15.5.16",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-virtuoso": "^4.0.0",
    "@tanstack/react-query": "^5.60.0",
    "framer-motion": "^11.0.0",
    "zod": "^3.25.23"
