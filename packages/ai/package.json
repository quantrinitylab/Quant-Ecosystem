    "safety:eval": "vitest run src/__tests__/safety-eval.test.ts --reporter=verbose",
    "lint": "eslint ."
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^1.0.0",
    "@ai-sdk/cohere": "^3.0.36",
    "@ai-sdk/deepinfra": "^2.0.52",
    "@ai-sdk/deepseek": "^2.0.35",
    "@ai-sdk/fireworks": "^2.0.53",
    "@ai-sdk/google": "^3.0.79",
    "@ai-sdk/groq": "^3.0.39",
    "@ai-sdk/mistral": "^3.0.37",
    "@ai-sdk/openai": "^1.0.0",
    "@ai-sdk/togetherai": "^2.0.53",
    "@anthropic-ai/sdk": "^0.32.0",
    "@aws-sdk/client-bedrock-runtime": "^3.700.0",
    "@quant/common": "workspace:*",
    "@quant/quant-tools": "workspace:*",
    "ai": "^5.0.52",
    "js-yaml": "^4.2.0",
    "ollama-ai-provider": "^1.2.0",
    "openai": "^4.73.0",
    "zod": "^3.23.0"
