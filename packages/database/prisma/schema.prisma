  role      EditCollaboratorRole @default(VIEWER)
  createdAt DateTime             @default(now())

  @@unique([projectId, userId])
  @@index([projectId])
  @@map("edit_collaborators")
}

model EditComment {
  id        String   @id @default(cuid())
  projectId String
  userId    String
  content   String
  layerId   String?
  position  Json?
  resolved  Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([projectId])
  @@map("edit_comments")
}



// ==================== QuantMax Video Chat (Omegle-style) ====================

enum VideoChatSessionStatus {
  CONNECTED
  ENDED
  SKIPPED
}

model VideoChatSession {
  id               String                 @id @default(cuid())
  user1Id          String
  user2Id          String
  status           VideoChatSessionStatus @default(CONNECTED)
  matchedInterests Json                   @default("[]")
  hasTextFallback  Boolean                @default(false)
  startedAt        DateTime               @default(now())
  endedAt          DateTime?
  durationSec      Int                    @default(0)

  @@index([user1Id])
  @@index([user2Id])
  @@map("video_chat_sessions")
}



// ==================== QuantMax Live Streaming ====================

enum LiveStreamType {
  SOLO
  DATING_EVENT
  SPEED_DATING
  GROUP_VIDEO
  PARTY
}

model LiveStream {
  id              String         @id @default(cuid())
  hostId          String
  title           String
  type            LiveStreamType @default(SOLO)
  thumbnailUrl    String?
  viewerCount     Int            @default(0)
  maxParticipants Int            @default(0)
  isLive          Boolean        @default(true)
  tags            Json           @default("[]")
  startedAt       DateTime       @default(now())
  endedAt         DateTime?

  @@index([isLive])
  @@index([hostId])
  @@map("live_streams")
}

model LiveStreamViewer {
  id       String   @id @default(cuid())
  streamId String
  userId   String
  joinedAt DateTime @default(now())

  @@unique([streamId, userId])
  @@index([streamId])
  @@map("live_stream_viewers")
}

// ==================== QuantSync Engagement (votes + bookmarks) ====================

model PostVote {
  id        String   @id @default(cuid())
  userId    String
  postId    String
  value     Int
  createdAt DateTime @default(now())

  @@unique([userId, postId])
  @@index([postId])
  @@map("post_votes")
}

model PostBookmark {
  id        String   @id @default(cuid())
  userId    String
  postId    String
  createdAt DateTime @default(now())

  @@unique([userId, postId])
  @@index([userId])
  @@map("post_bookmarks")
}

// ==================== QuantDocs (Google Docs killer) ====================

model Document {
  id        String   @id @default(cuid())
  title     String
  content   String   @default("")
  userId    String
  metadata  Json     @default("{}")
  isPublic  Boolean  @default(false)
  isDeleted Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  versions      DocumentVersion[]
  comments      DocComment[]
  suggestions   DocSuggestion[]
  collaborators DocumentCollaborator[]

  @@index([userId])
  @@index([userId, isDeleted, updatedAt])
  @@map("documents")
}

model DocumentVersion {
  id        String   @id @default(cuid())
  docId     String
  title     String
  content   String
  createdAt DateTime @default(now())

  document Document @relation(fields: [docId], references: [id], onDelete: Cascade)

  @@index([docId])
  @@map("document_versions")
}

model DocComment {
  id        String   @id @default(cuid())
  docId     String
  userId    String
  content   String
  selection Json?
  parentId  String?
  resolved  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  document Document     @relation(fields: [docId], references: [id], onDelete: Cascade)
  parent   DocComment?  @relation("DocCommentReplies", fields: [parentId], references: [id])
  replies  DocComment[] @relation("DocCommentReplies")

  @@index([docId])
  @@index([parentId])
  @@map("doc_comments")
}

model DocSuggestion {
  id            String   @id @default(cuid())
  docId         String
  userId        String
  originalText  String
  suggestedText String
  selection     Json
  status        String   @default("pending")
  createdAt     DateTime @default(now())

  document Document @relation(fields: [docId], references: [id], onDelete: Cascade)

  @@index([docId])
  @@map("doc_suggestions")
}

model DocumentCollaborator {
  id        String   @id @default(cuid())
  docId     String
  userId    String
  role      String   @default("viewer")
  createdAt DateTime @default(now())

  document Document @relation(fields: [docId], references: [id], onDelete: Cascade)

  @@unique([docId, userId])
  @@index([docId])
  @@map("document_collaborators")
}



// ==================== QuantDrive (Google Drive killer) ====================

model File {
  id                String    @id @default(cuid())
  name              String
  mimeType          String
  size              Int       @default(0)
  encryptedContent  String
  encryptionIV      String
  encryptionAuthTag String
  encryptionKey     String
  contentHash       String
  userId            String
  folderId          String?
  isDeleted         Boolean   @default(false)
  deletedAt         DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  @@index([userId, isDeleted])
  @@index([folderId])
  @@map("drive_files")
}

model Folder {
  id        String   @id @default(cuid())
  name      String
  userId    String
  parentId  String?
  path      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([parentId])
  @@map("drive_folders")
}

model Share {
  id               String   @id @default(cuid())
  fileId           String?
  folderId         String?
  ownerUserId      String
  sharedWithUserId String
  encryptedFileKey String
  permission       String   @default("read")
  status           String   @default("pending")
  createdAt        DateTime @default(now())

  @@index([ownerUserId])
  @@index([sharedWithUserId])
  @@index([fileId])
  @@map("drive_shares")
}

model FileVersion {
  id                String   @id @default(cuid())
  fileId            String
  versionNumber     Int      @default(0)
  encryptedContent  String
  encryptionIV      String
  encryptionAuthTag String
  encryptionKey     String
  size              Int      @default(0)
  createdAt         DateTime @default(now())

  @@index([fileId])
  @@map("drive_file_versions")
}

model FileIndex {
  id        String   @id @default(cuid())
  fileId    String
  userId    String
  content   String
  mimeType  String
  indexedAt DateTime @default(now())

  @@index([userId])
  @@index([fileId])
  @@map("drive_file_indexes")
}

model UserSubscription {
  userId    String   @id
  tier      String   @default("FREE")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("drive_user_subscriptions")
}



// ==================== QuantCalendar (Google Calendar killer) ====================

model Event {
  id             String   @id @default(cuid())
  title          String
  description    String   @default("")
  startTime      DateTime
  endTime        DateTime
  allDay         Boolean  @default(false)
  location       String   @default("")
  userId         String
  attendees      String   @default("[]")
  recurrenceRule String?
  status         String   @default("confirmed")
  reminders      String   @default("[]")
  createdAt      DateTime
  updatedAt      DateTime

  @@index([userId, startTime])
  @@map("calendar_events")
}

model BookingLink {
  id            String   @id @default(cuid())
  userId        String
  slug          String   @unique
  title         String
  description   String   @default("")
  duration      Int
  availableDays String   @default("[1,2,3,4,5]")
  startHour     Int      @default(9)
  endHour       Int      @default(17)
  isActive      Boolean  @default(true)
  createdAt     DateTime
  updatedAt     DateTime

  @@index([userId])
  @@map("booking_links")
}

model Calendar {
  id        String   @id @default(cuid())
  userId    String
  name      String
  color     String?
  isPrimary Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@map("calendars")
}

// QuantTrinity owner control-plane state. A single durable document (one row,
// id = "singleton") holding the owner's team, app registry, model registry,
// payouts, revenue streams, reports and audit trail. Replaces the previous
// in-memory `globalThis.__trinity` store so owner state survives restarts and
// is shared across backend instances. The shape is owned by the app's
// `TrinityState` type; `data` is the serialized document. (The credit/economy
// config is persisted separately by @quant/credits.)
model TrinityControlState {
  id        String   @id @default("singleton")
  data      Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("trinity_control_state")
}
