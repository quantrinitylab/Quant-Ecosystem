model ReelLike {
  id        String   @id @default(cuid())
  reelId    String
  userId    String
  createdAt DateTime @default(now())

  reel Reel @relation(fields: [reelId], references: [id], onDelete: Cascade)

  @@unique([reelId, userId])
  @@index([reelId])
  @@index([userId])
  @@map("reel_likes")
