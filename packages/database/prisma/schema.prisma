generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [vector]
}

// ==================== USERS & AUTH ====================

model User {
  id                  String     @id @default(cuid())
  email               String     @unique
  username            String     @unique
  displayName         String
  passwordHash        String
  avatarUrl           String?
  bannerUrl           String?
  phoneNumber         String?    @unique
  role                UserRole   @default(USER)
  status              UserStatus @default(PENDING_VERIFICATION)
  emailVerified       Boolean    @default(false)
  phoneVerified       Boolean    @default(false)
  isVerified          Boolean    @default(false)
  twoFactorEnabled    Boolean    @default(false)
  twoFactorSecret     String?
  bio                 String?
  website             String?
  location            String?
  dateOfBirth         DateTime?
  lastLoginAt         DateTime?
  lastLoginIp         String?
  loginCount          Int        @default(0)
  failedLoginAttempts Int        @default(0)
  lockoutUntil        DateTime?
  preferences         Json       @default("{}")
  metadata            Json       @default("{}")
  xpPoints            Int        @default(0)
  level               Int        @default(1)
  ghostMode           Boolean    @default(false)
  createdAt           DateTime   @default(now())
  updatedAt           DateTime   @updatedAt
  deletedAt           DateTime?

  // Relations
  oauthAccounts      OAuthAccount[]
  sessions           Session[]
  refreshTokens      RefreshToken[]
  oauthClients       OAuthClient[]        @relation("UserOwnedClients")
  oauthConsents      OAuthConsent[]
  authorizationCodes AuthorizationCode[]
  sentMessages       Message[]            @relation("MessageSender")
  conversations      ConversationMember[]
  emails             Email[]
  posts              Post[]
  comments           Comment[]
  videos             Video[]
  photos             Photo[]
  stories            Story[]
  notifications      Notification[]
  aiSessions         AISession[]
  campaigns          Campaign[]
  datingProfile      DatingProfile?
  shortVideos        ShortVideo[]

  // Git hosting relations
  repositories   Repository[]
  pullRequests   PullRequest[]
  reviews        Review[]
  reviewComments ReviewComment[]
  issues         Issue[]
  agentSessions  AgentSession[]
  agentOrgs      AgentOrg[]

  // QuantMail relations
  labels   Label[]
  contacts Contact[]

  // QuantMail productivity features
  mailFilters       MailFilter[]
  vacationResponder VacationResponder?
  vacationReplyLogs VacationAutoReplyLog[]
  emailTemplates    EmailTemplate[]
  emailSignatures   EmailSignature[]

  // Self-relations for followers
  following UserRelationship[] @relation("UserFollowing")
  followers UserRelationship[] @relation("UserFollower")

  // Dating/matching relations
  matchesAsUser1 Match[] @relation("MatchUser1")
  matchesAsUser2 Match[] @relation("MatchUser2")
  swipesGiven    Swipe[] @relation("SwipeSwiper")
  swipesReceived Swipe[] @relation("SwipeTarget")
  likes          Like[]

  // Community membership
  communityMemberships CommunityMember[]

  // QuantChat Mega Upgrade relations
  reels              Reel[]
  streaksA           Streak[]          @relation("streakUserA")
  streaksB           Streak[]          @relation("streakUserB")
  gameBadges         GameBadge[]
  gameScores         GameScore[]
  memories           Memory[]
  pushSubscriptions  PushSubscription[]
  scheduledMessages  ScheduledMessage[]
  quantAvatar        Avatar?           @relation()
  preKeyBundle       PreKeyBundle?

  @@index([email])
  @@index([username])
  @@index([phoneNumber])
  @@index([status])
  @@index([createdAt])
  @@map("users")
}

enum UserRole {
  USER
  ADMIN
  MODERATOR
  CREATOR
  ADVERTISER
}

enum UserStatus {
  ACTIVE
  SUSPENDED
  DEACTIVATED
  PENDING_VERIFICATION
}

model OAuthAccount {
  id                String    @id @default(cuid())
  userId            String
  provider          String
  providerAccountId String
  accessToken       String?
  refreshToken      String?
  expiresAt         DateTime?
  scope             String    @default("")
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
  @@map("oauth_accounts")
}

model UserRelationship {
  id          String           @id @default(cuid())
  followerId  String
  followingId String
  type        RelationshipType @default(FOLLOW)
  createdAt   DateTime         @default(now())

  follower  User @relation("UserFollowing", fields: [followerId], references: [id], onDelete: Cascade)
  following User @relation("UserFollower", fields: [followingId], references: [id], onDelete: Cascade)

  @@unique([followerId, followingId])
  @@index([followerId])
  @@index([followingId])
  @@map("user_relationships")
}

enum RelationshipType {
  FOLLOW
  BLOCK
  MUTE
  CLOSE_FRIEND
}

model Session {
  id         String   @id @default(cuid())
  userId     String
  token      String   @unique
  deviceInfo Json     @default("{}")
  ipAddress  String?
  userAgent  String?
  expiresAt  DateTime
  createdAt  DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([token])
  @@index([expiresAt])
  @@map("sessions")
}

model RefreshToken {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  family    String
  isRevoked Boolean  @default(false)
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([token])
  @@index([family])
  @@map("refresh_tokens")
}

model OAuthClient {
  id               String   @id @default(cuid())
  clientId         String   @unique
  clientSecretHash String?
  name             String
  description      String?  @default("")
  redirectUris     String[]
  allowedScopes    String[]
  isConfidential   Boolean  @default(true)
  isFirstParty     Boolean  @default(false)
  ownerId          String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  owner User? @relation("UserOwnedClients", fields: [ownerId], references: [id], onDelete: Cascade)

  @@index([clientId])
  @@index([ownerId])
  @@map("oauth_clients")
}

model OAuthConsent {
  id        String   @id @default(cuid())
  userId    String
  clientId  String
  scopes    String[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, clientId])
  @@index([userId])
  @@index([clientId])
  @@map("oauth_consents")
}

model AuthorizationCode {
  id                  String   @id @default(cuid())
  code                String   @unique
  clientId            String
  userId              String
  redirectUri         String
  scopes              String[]
  codeChallenge       String?
  codeChallengeMethod String?
  nonce               String?
  expiresAt           DateTime
  createdAt           DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([code])
  @@index([userId])
  @@map("authorization_codes")
}

// ==================== MESSAGES (QuantChat) ====================

model Conversation {
  id            String           @id @default(cuid())
  type          ConversationType @default(DIRECT)
  name          String?
  description   String?
  avatarUrl     String?
  createdBy     String
  themeId       String?
  disappearTimer Int?            // seconds, null = no timer
  isArchived    Boolean          @default(false)
  lastMessageAt DateTime?
  metadata      Json             @default("{}")
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt
  deletedAt     DateTime?

  members  ConversationMember[]
  messages Message[]

  @@index([createdBy])
  @@index([lastMessageAt])
  @@index([updatedAt])
  @@map("conversations")
}

enum ConversationType {
  DIRECT
  GROUP
  CHANNEL
}

model ConversationMember {
  id             String           @id @default(cuid())
  conversationId String
  userId         String
  role           ConversationRole @default(MEMBER)
  nickname       String?
  isMuted        Boolean          @default(false)
  muteUntil      DateTime?
  joinedAt       DateTime         @default(now())
  leftAt         DateTime?
  lastReadAt     DateTime?

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([conversationId, userId])
  @@index([conversationId])
  @@index([userId])
  @@map("conversation_members")
}

enum ConversationRole {
  OWNER
  ADMIN
  MEMBER
}

model Message {
  id                String      @id @default(cuid())
  conversationId    String
  senderId          String
  type              MessageType @default(TEXT)
  content           String?
  mediaUrl          String?
  mediaThumbnailUrl String?
  mediaType         String?
  mediaDuration     Int?
  replyToId         String?
  isEdited          Boolean     @default(false)
  isDeleted         Boolean     @default(false)
  isAIGenerated     Boolean     @default(false)
  expiresAt         DateTime?
  mentions          Json        @default("[]")
  metadata          Json        @default("{}")
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt

  conversation Conversation      @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender       User              @relation("MessageSender", fields: [senderId], references: [id], onDelete: Cascade)
  replyTo      Message?          @relation("MessageReplies", fields: [replyToId], references: [id])
  replies      Message[]         @relation("MessageReplies")
  reactions    MessageReaction[]

  @@index([conversationId])
  @@index([senderId])
  @@index([createdAt])
  @@index([expiresAt])
  @@map("messages")
}

enum MessageType {
  TEXT
  IMAGE
  VIDEO
  AUDIO
  FILE
  STICKER
  GIF
  LOCATION
  CONTACT
  POLL
  SYSTEM
}

model MessageReaction {
  id        String   @id @default(cuid())
  messageId String
  userId    String
  emoji     String
  createdAt DateTime @default(now())

  message Message @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@unique([messageId, userId, emoji])
  @@index([messageId])
  @@map("message_reactions")
}

// ==================== EMAILS (QuantMail) ====================

model Email {
  id             String        @id @default(cuid())
  userId         String
  threadId       String?
  folderId       String?
  fromAddress    String
  fromName       String?
  toAddresses    Json          @default("[]")
  ccAddresses    Json          @default("[]")
  bccAddresses   Json          @default("[]")
  subject        String
  bodyHtml       String?
  bodyPlain      String?
  snippet        String?
  isRead         Boolean       @default(false)
  isStarred      Boolean       @default(false)
  isImportant    Boolean       @default(false)
  isDraft        Boolean       @default(false)
  isSent         Boolean       @default(false)
  isSpam         Boolean       @default(false)
  isTrash        Boolean       @default(false)
  hasAttachments Boolean       @default(false)
  attachments    Json          @default("[]")
  labels         Json          @default("[]")
  inReplyTo      String?
  // Real outbound/inbound delivery (QuantMail SuperHub Pillar 1). Additive; existing
  // rows default to `draft`. Advanced toward a terminal state by the OutboundDeliveryPipeline.
  deliveryStatus EmailDeliveryStatus @default(draft)
  messageId      String?
  // Combined SPF/DKIM/DMARC AuthVerdict recorded by the InboundIngestAdapter for
  // inbound mail (QuantMail SuperHub Pillar 1, Requirement 5.1). Additive/nullable;
  // outbound and existing rows leave it null.
  authResults    Json?
  priority       EmailPriority @default(NORMAL)
  aiSummary      String?
  aiCategory     String?
  sentAt         DateTime?
  receivedAt     DateTime?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  deletedAt      DateTime?

  user   User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  thread EmailThread? @relation(fields: [threadId], references: [id])
  folder EmailFolder? @relation(fields: [folderId], references: [id])

  // Per-recipient delivery attempts recorded by the OutboundDeliveryPipeline worker.
  deliveryAttempts DeliveryAttempt[]

  @@index([userId])
  @@index([threadId])
  @@index([folderId])
  @@index([isRead])
  @@index([receivedAt])
  @@map("emails")
}

enum EmailPriority {
  LOW
  NORMAL
  HIGH
  URGENT
}

// Per-email/per-recipient delivery lifecycle for real outbound/inbound mail.
// Values are lowercase to match the design's Delivery_State literals
// (draft -> queued -> sent/deferred -> bounced/delivered) and never regress.
enum EmailDeliveryStatus {
  draft
  queued
  sent
  deferred
  bounced
  delivered
}

model EmailThread {
  id                   String    @id @default(cuid())
  userId               String
  subject              String
  participantAddresses Json      @default("[]")
  messageCount         Int       @default(0)
  isRead               Boolean   @default(false)
  isStarred            Boolean   @default(false)
  isMuted              Boolean   @default(false)
  snoozedUntil         DateTime?
  lastEmailAt          DateTime?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  emails Email[]

  @@index([userId])
  @@index([lastEmailAt])
  @@map("email_threads")
}

model EmailFolder {
  id          String          @id @default(cuid())
  userId      String
  name        String
  type        EmailFolderType @default(CUSTOM)
  color       String?
  icon        String?
  emailCount  Int             @default(0)
  unreadCount Int             @default(0)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  emails Email[]

  @@unique([userId, name])
  @@index([userId])
  @@map("email_folders")
}

enum EmailFolderType {
  INBOX
  SENT
  DRAFTS
  SPAM
  TRASH
  ARCHIVE
  CUSTOM
}

// ==================== POSTS (QuantSync) ====================

model Post {
  id               String           @id @default(cuid())
  userId           String
  type             PostType         @default(TEXT)
  content          String?
  mediaUrls        Json             @default("[]")
  hashtags         Json             @default("[]")
  mentions         Json             @default("[]")
  linkPreview      Json?
  replyToId        String?
  communityId      String?
  visibility       PostVisibility   @default(PUBLIC)
  likeCount        Int              @default(0)
  commentCount     Int              @default(0)
  repostCount      Int              @default(0)
  shareCount       Int              @default(0)
  viewCount        Int              @default(0)
  isEdited         Boolean          @default(false)
  isPinned         Boolean          @default(false)
  isAnonymous      Boolean          @default(false)
  anonymousAlias   String?
  space            String           @default("main")
  moderationStatus ModerationStatus @default(APPROVED)
  publishedAt      DateTime?
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  deletedAt        DateTime?

  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  replyTo   Post?      @relation("PostReplies", fields: [replyToId], references: [id])
  replies   Post[]     @relation("PostReplies")
  community Community? @relation(fields: [communityId], references: [id])
  comments  Comment[]
  poll      Poll?
  likes     Like[]

  @@index([userId])
  @@index([communityId])
  @@index([publishedAt])
  @@index([visibility])
  @@index([isAnonymous])
  @@index([space])
  @@map("posts")
}

enum PostType {
  TEXT
  IMAGE
  VIDEO
  POLL
  LINK
  REPOST
  THREAD
  ARTICLE
}

enum PostVisibility {
  PUBLIC
  FOLLOWERS_ONLY
  PRIVATE
  COMMUNITY_ONLY
}

enum ModerationStatus {
  PENDING
  APPROVED
  REJECTED
  FLAGGED
}

model Comment {
  id         String    @id @default(cuid())
  postId     String
  userId     String
  parentId   String?
  content    String
  mediaUrl   String?
  likeCount  Int       @default(0)
  replyCount Int       @default(0)
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  deletedAt  DateTime?

  post    Post      @relation(fields: [postId], references: [id], onDelete: Cascade)
  user    User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  parent  Comment?  @relation("CommentReplies", fields: [parentId], references: [id])
  replies Comment[] @relation("CommentReplies")

  @@index([postId])
  @@index([userId])
  @@index([parentId])
  @@map("comments")
}

model Community {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  description String?
  avatarUrl   String?
  bannerUrl   String?
  category    String?
  rules       Json     @default("[]")
  memberCount Int      @default(0)
  isPrivate   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  posts   Post[]
  members CommunityMember[]

  @@index([slug])
  @@map("communities")
}

model CommunityMember {
  id          String        @id @default(cuid())
  communityId String
  userId      String
  role        CommunityRole @default(MEMBER)
  joinedAt    DateTime      @default(now())

  community Community @relation(fields: [communityId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([communityId, userId])
  @@index([communityId])
  @@index([userId])
  @@map("community_members")
}

enum CommunityRole {
  OWNER
  ADMIN
  MODERATOR
  MEMBER
}

model Poll {
  id            String    @id @default(cuid())
  postId        String    @unique
  question      String
  options       Json      @default("[]")
  endAt         DateTime?
  voterCount    Int       @default(0)
  allowMultiple Boolean   @default(false)
  createdAt     DateTime  @default(now())

  post  Post       @relation(fields: [postId], references: [id], onDelete: Cascade)
  votes PollVote[]

  @@map("polls")
}

model PollVote {
  id          String   @id @default(cuid())
  pollId      String
  userId      String
  optionIndex Int
  createdAt   DateTime @default(now())

  poll Poll @relation(fields: [pollId], references: [id], onDelete: Cascade)

  @@unique([pollId, userId, optionIndex])
  @@index([pollId])
  @@map("poll_votes")
}

// ==================== ADS (QuantAds) ====================

model Campaign {
  id               String            @id @default(cuid())
  advertiserId     String
  name             String
  objective        CampaignObjective @default(AWARENESS)
  status           CampaignStatus    @default(DRAFT)
  budget           Json              @default("{}")
  schedule         Json              @default("{}")
  targeting        Json              @default("{}")
  totalSpend       Float             @default(0)
  totalImpressions Int               @default(0)
  totalClicks      Int               @default(0)
  totalConversions Int               @default(0)
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  deletedAt        DateTime?

  advertiser User    @relation(fields: [advertiserId], references: [id], onDelete: Cascade)
  adSets     AdSet[]

  @@index([advertiserId])
  @@index([status])
  @@map("campaigns")
}

enum CampaignObjective {
  AWARENESS
  TRAFFIC
  ENGAGEMENT
  LEADS
  CONVERSIONS
  APP_INSTALLS
}

enum CampaignStatus {
  DRAFT
  PENDING_REVIEW
  ACTIVE
  PAUSED
  COMPLETED
  REJECTED
}

model AdSet {
  id         String      @id @default(cuid())
  campaignId String
  name       String
  status     AdSetStatus @default(DRAFT)
  budget     Json        @default("{}")
  targeting  Json        @default("{}")
  placement  Json        @default("[]")
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt

  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  ads      Ad[]

  @@index([campaignId])
  @@map("ad_sets")
}

enum AdSetStatus {
  DRAFT
  ACTIVE
  PAUSED
  COMPLETED
}

model Ad {
  id         String   @id @default(cuid())
  adSetId    String
  creativeId String
  name       String
  status     AdStatus @default(DRAFT)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  adSet    AdSet      @relation(fields: [adSetId], references: [id], onDelete: Cascade)
  creative AdCreative @relation(fields: [creativeId], references: [id])

  @@index([adSetId])
  @@index([creativeId])
  @@map("ads")
}

enum AdStatus {
  DRAFT
  ACTIVE
  PAUSED
  REJECTED
}

model AdCreative {
  id           String         @id @default(cuid())
  advertiserId String
  type         AdCreativeType @default(IMAGE)
  name         String
  headline     String?
  description  String?
  mediaUrl     String?
  callToAction String?
  landingUrl   String?
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  ads Ad[]

  @@index([advertiserId])
  @@map("ad_creatives")
}

enum AdCreativeType {
  IMAGE
  VIDEO
  CAROUSEL
  COLLECTION
}

/// A durable per-click record for QuantAds click-fraud accounting. Every click
/// on the serving surface is recorded here with a fraud verdict; only clicks
/// with `billable = true` (not flagged) charge the advertiser and count toward
/// publisher payouts. Relation-free (additive) so it is safe for the shared
/// schema. `ipHash` is a salted hash — never a raw IP.
model AdClickEvent {
  id         String   @id @default(cuid())
  adId       String
  campaignId String?
  publisherId String?
  userId     String
  ipHash     String?
  deviceFp   String?
  billable   Boolean  @default(true)
  paidOut    Boolean  @default(false)
  fraudFlag  Boolean  @default(false)
  fraudReason String?
  createdAt  DateTime @default(now())

  @@index([adId])
  @@index([userId, createdAt])
  @@index([ipHash, createdAt])
  @@index([publisherId, billable, paidOut])
  @@map("ad_click_events")
}

/// A durable record of one daily publisher-payout batch. `utcDay` is unique so
/// a re-run for the same day is idempotent. Counts give an at-a-glance audit of
/// how many publishers were paid / skipped / failed and the total credits paid.
model PublisherPayoutRun {
  id                  String    @id @default(cuid())
  utcDay              String    @unique
  status              String    @default("running") // running | completed | failed
  publishersConsidered Int      @default(0)
  paid                Int       @default(0)
  skipped             Int       @default(0)
  failed              Int       @default(0)
  totalCreditsPaid    Int       @default(0)
  error               String?
  startedAt           DateTime  @default(now())
  finishedAt          DateTime?

  @@map("publisher_payout_runs")
}

// ==================== MEDIA (QuantTube / QuantNeon) ====================

model Video {
  id               String                @id @default(cuid())
  userId           String
  channelId        String?
  title            String
  description      String?
  videoUrl         String
  thumbnailUrl     String?
  duration         Int                   @default(0)
  width            Int?
  height           Int?
  fileSize         BigInt                @default(0)
  category         String?
  tags             Json                  @default("[]")
  visibility       VideoVisibility       @default(PUBLIC)
  ageRestricted    Boolean               @default(false)
  viewCount        Int                   @default(0)
  likeCount        Int                   @default(0)
  commentCount     Int                   @default(0)
  processingStatus VideoProcessingStatus @default(PENDING)
  publishedAt      DateTime?
  createdAt        DateTime              @default(now())
  updatedAt        DateTime              @updatedAt
  deletedAt        DateTime?

  user    User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  channel VideoChannel? @relation(fields: [channelId], references: [id])

  @@index([userId])
  @@index([channelId])
  @@index([publishedAt])
  @@index([visibility])
  @@map("videos")
}

/// AI/creator-defined content segments of a video, used to compute a skip-plan
/// so playback can show only the useful parts (skip intros, sponsors, recaps,
/// outros, filler). Relation-free + additive (no Video back-relation) so it is
/// safe for the shared schema.
model VideoSegment {
  id        String   @id @default(cuid())
  videoId   String
  kind      String // intro | content | sponsor | recap | outro | filler
  label     String?
  startSec  Float
  endSec    Float
  source    String   @default("ai") // ai | creator | community
  createdAt DateTime @default(now())

  @@index([videoId])
  @@map("video_segments")
}

enum VideoVisibility {
  PUBLIC
  UNLISTED
  PRIVATE
}

enum VideoProcessingStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

model VideoChannel {
  id              String   @id @default(cuid())
  userId          String
  name            String
  handle          String   @unique
  description     String?
  avatarUrl       String?
  bannerUrl       String?
