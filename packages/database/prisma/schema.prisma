generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [vector]
}

// ==================== USERS & AUTH ====================

model User {
  id                  String     @id @default(cuid())
  email               String     @unique
  username            String     @unique
  displayName         String
  passwordHash        String
  avatarUrl           String?
  bannerUrl           String?
  phoneNumber         String?    @unique
  role                UserRole   @default(USER)
  status              UserStatus @default(PENDING_VERIFICATION)
  emailVerified       Boolean    @default(false)
  phoneVerified       Boolean    @default(false)
  twoFactorEnabled    Boolean    @default(false)
  twoFactorSecret     String?
  bio                 String?
  website             String?
  location            String?
  dateOfBirth         DateTime?
  lastLoginAt         DateTime?
  lastLoginIp         String?
  loginCount          Int        @default(0)
  failedLoginAttempts Int        @default(0)
  lockoutUntil        DateTime?
  preferences         Json       @default("{}")
  metadata            Json       @default("{}")
  createdAt           DateTime   @default(now())
  updatedAt           DateTime   @updatedAt
  deletedAt           DateTime?

  // Relations
  oauthAccounts       OAuthAccount[]
  sessions            Session[]
  refreshTokens       RefreshToken[]
  sentMessages        Message[]          @relation("MessageSender")
  conversations       ConversationMember[]
  emails              Email[]
  posts               Post[]
  comments            Comment[]
  videos              Video[]
  photos              Photo[]
  stories             Story[]
  notifications       Notification[]
  aiSessions          AISession[]
  campaigns           Campaign[]
  datingProfile       DatingProfile?
  shortVideos         ShortVideo[]

  // Git hosting relations
  repositories        Repository[]
  pullRequests        PullRequest[]
  reviews             Review[]
  reviewComments      ReviewComment[]
  issues              Issue[]

  // Self-relations for followers
  following           UserRelationship[] @relation("UserFollowing")
  followers           UserRelationship[] @relation("UserFollower")

  // Dating/matching relations
  matchesAsUser1      Match[]            @relation("MatchUser1")
  matchesAsUser2      Match[]            @relation("MatchUser2")
  swipesGiven         Swipe[]            @relation("SwipeSwiper")
  swipesReceived      Swipe[]            @relation("SwipeTarget")

  // Community membership
  communityMemberships CommunityMember[]

  @@index([email])
  @@index([username])
  @@index([phoneNumber])
  @@index([status])
  @@index([createdAt])
  @@map("users")
}

enum UserRole {
  USER
  ADMIN
  MODERATOR
  CREATOR
  ADVERTISER
}

enum UserStatus {
  ACTIVE
  SUSPENDED
  DEACTIVATED
  PENDING_VERIFICATION
}

model OAuthAccount {
  id                String   @id @default(cuid())
  userId            String
  provider          String
  providerAccountId String
  accessToken       String?
  refreshToken      String?
  expiresAt         DateTime?
  scope             String   @default("")
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
  @@map("oauth_accounts")
}

model UserRelationship {
  id          String           @id @default(cuid())
  followerId  String
  followingId String
  type        RelationshipType @default(FOLLOW)
  createdAt   DateTime         @default(now())

  follower    User             @relation("UserFollowing", fields: [followerId], references: [id], onDelete: Cascade)
  following   User             @relation("UserFollower", fields: [followingId], references: [id], onDelete: Cascade)

  @@unique([followerId, followingId])
  @@index([followerId])
  @@index([followingId])
  @@map("user_relationships")
}

enum RelationshipType {
  FOLLOW
  BLOCK
  MUTE
  CLOSE_FRIEND
}

model Session {
  id         String   @id @default(cuid())
  userId     String
  token      String   @unique
  deviceInfo Json     @default("{}")
  ipAddress  String?
  userAgent  String?
  expiresAt  DateTime
  createdAt  DateTime @default(now())

  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([token])
  @@index([expiresAt])
  @@map("sessions")
}

model RefreshToken {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  family    String
  isRevoked Boolean  @default(false)
  expiresAt DateTime
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([token])
  @@index([family])
  @@map("refresh_tokens")
}

// ==================== MESSAGES (QuantChat) ====================

model Conversation {
  id            String             @id @default(cuid())
  type          ConversationType   @default(DIRECT)
  name          String?
  description   String?
  avatarUrl     String?
  createdBy     String
  isArchived    Boolean            @default(false)
  lastMessageAt DateTime?
  metadata      Json               @default("{}")
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt
  deletedAt     DateTime?

  members       ConversationMember[]
  messages      Message[]

  @@index([createdBy])
  @@index([lastMessageAt])
  @@map("conversations")
}

enum ConversationType {
  DIRECT
  GROUP
  CHANNEL
}

model ConversationMember {
  id             String               @id @default(cuid())
  conversationId String
  userId         String
  role           ConversationRole     @default(MEMBER)
  nickname       String?
  isMuted        Boolean              @default(false)
  muteUntil      DateTime?
  joinedAt       DateTime             @default(now())
  leftAt         DateTime?
  lastReadAt     DateTime?

  conversation   Conversation         @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  user           User                 @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([conversationId, userId])
  @@index([conversationId])
  @@index([userId])
  @@map("conversation_members")
}

enum ConversationRole {
  OWNER
  ADMIN
  MEMBER
}

model Message {
  id                String          @id @default(cuid())
  conversationId    String
  senderId          String
  type              MessageType     @default(TEXT)
  content           String?
  mediaUrl          String?
  mediaThumbnailUrl String?
  mediaType         String?
  mediaDuration     Int?
  replyToId         String?
  isEdited          Boolean         @default(false)
  isDeleted         Boolean         @default(false)
  expiresAt         DateTime?
  mentions          Json            @default("[]")
  metadata          Json            @default("{}")
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  conversation      Conversation    @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender            User            @relation("MessageSender", fields: [senderId], references: [id], onDelete: Cascade)
  replyTo           Message?        @relation("MessageReplies", fields: [replyToId], references: [id])
  replies           Message[]       @relation("MessageReplies")
  reactions         MessageReaction[]

  @@index([conversationId])
  @@index([senderId])
  @@index([createdAt])
  @@map("messages")
}

enum MessageType {
  TEXT
  IMAGE
  VIDEO
  AUDIO
  FILE
  STICKER
  GIF
  LOCATION
  CONTACT
  POLL
  SYSTEM
}

model MessageReaction {
  id        String   @id @default(cuid())
  messageId String
  userId    String
  emoji     String
  createdAt DateTime @default(now())

  message   Message  @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@unique([messageId, userId, emoji])
  @@index([messageId])
  @@map("message_reactions")
}

// ==================== EMAILS (QuantMail) ====================

model Email {
  id             String        @id @default(cuid())
  userId         String
  threadId       String?
  folderId       String?
  fromAddress    String
  fromName       String?
  toAddresses    Json          @default("[]")
  ccAddresses    Json          @default("[]")
  bccAddresses   Json          @default("[]")
  subject        String
  bodyHtml       String?
  bodyPlain      String?
  snippet        String?
  isRead         Boolean       @default(false)
  isStarred      Boolean       @default(false)
  isImportant    Boolean       @default(false)
  isDraft        Boolean       @default(false)
  isSent         Boolean       @default(false)
  isSpam         Boolean       @default(false)
  isTrash        Boolean       @default(false)
  hasAttachments Boolean       @default(false)
  attachments    Json          @default("[]")
  labels         Json          @default("[]")
  inReplyTo      String?
  priority       EmailPriority @default(NORMAL)
  aiSummary      String?
  aiCategory     String?
  sentAt         DateTime?
  receivedAt     DateTime?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  deletedAt      DateTime?

  user           User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  thread         EmailThread?  @relation(fields: [threadId], references: [id])
  folder         EmailFolder?  @relation(fields: [folderId], references: [id])

  @@index([userId])
  @@index([threadId])
  @@index([folderId])
  @@index([isRead])
  @@index([receivedAt])
  @@map("emails")
}

enum EmailPriority {
  LOW
  NORMAL
  HIGH
  URGENT
}

model EmailThread {
  id                   String   @id @default(cuid())
  userId               String
  subject              String
  participantAddresses Json     @default("[]")
  messageCount         Int      @default(0)
  isRead               Boolean  @default(false)
  isStarred            Boolean  @default(false)
  lastEmailAt          DateTime?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  emails               Email[]

  @@index([userId])
  @@index([lastEmailAt])
  @@map("email_threads")
}

model EmailFolder {
  id          String          @id @default(cuid())
  userId      String
  name        String
  type        EmailFolderType @default(CUSTOM)
  color       String?
  icon        String?
  emailCount  Int             @default(0)
  unreadCount Int             @default(0)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  emails      Email[]

  @@unique([userId, name])
  @@index([userId])
  @@map("email_folders")
}

enum EmailFolderType {
  INBOX
  SENT
  DRAFTS
  SPAM
  TRASH
  ARCHIVE
  CUSTOM
}

// ==================== POSTS (QuantSync) ====================

model Post {
  id               String           @id @default(cuid())
  userId           String
  type             PostType         @default(TEXT)
  content          String?
  mediaUrls        Json             @default("[]")
  hashtags         Json             @default("[]")
  mentions         Json             @default("[]")
  linkPreview      Json?
  replyToId        String?
  communityId      String?
  visibility       PostVisibility   @default(PUBLIC)
  likeCount        Int              @default(0)
  commentCount     Int              @default(0)
  repostCount      Int              @default(0)
  viewCount        Int              @default(0)
  isEdited         Boolean          @default(false)
  isPinned         Boolean          @default(false)
  moderationStatus ModerationStatus @default(APPROVED)
  publishedAt      DateTime?
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  deletedAt        DateTime?

  user             User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  replyTo          Post?            @relation("PostReplies", fields: [replyToId], references: [id])
  replies          Post[]           @relation("PostReplies")
  community        Community?       @relation(fields: [communityId], references: [id])
  comments         Comment[]
  poll             Poll?

  @@index([userId])
  @@index([communityId])
  @@index([publishedAt])
  @@index([visibility])
  @@map("posts")
}

enum PostType {
  TEXT
  IMAGE
  VIDEO
  POLL
  LINK
  REPOST
  THREAD
  ARTICLE
}

enum PostVisibility {
  PUBLIC
  FOLLOWERS_ONLY
  PRIVATE
  COMMUNITY_ONLY
}

enum ModerationStatus {
  PENDING
  APPROVED
  REJECTED
  FLAGGED
}

model Comment {
  id        String    @id @default(cuid())
  postId    String
  userId    String
  parentId  String?
  content   String
  mediaUrl  String?
  likeCount Int       @default(0)
  replyCount Int      @default(0)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  post      Post      @relation(fields: [postId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  parent    Comment?  @relation("CommentReplies", fields: [parentId], references: [id])
  replies   Comment[] @relation("CommentReplies")

  @@index([postId])
  @@index([userId])
  @@index([parentId])
  @@map("comments")
}

model Community {
  id          String            @id @default(cuid())
  name        String
  slug        String            @unique
  description String?
  avatarUrl   String?
  bannerUrl   String?
  category    String?
  rules       Json              @default("[]")
  memberCount Int               @default(0)
  isPrivate   Boolean           @default(false)
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  posts       Post[]
  members     CommunityMember[]

  @@index([slug])
  @@map("communities")
}

model CommunityMember {
  id          String        @id @default(cuid())
  communityId String
  userId      String
  role        CommunityRole @default(MEMBER)
  joinedAt    DateTime      @default(now())

  community   Community     @relation(fields: [communityId], references: [id], onDelete: Cascade)
  user        User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([communityId, userId])
  @@index([communityId])
  @@index([userId])
  @@map("community_members")
}

enum CommunityRole {
  OWNER
  ADMIN
  MODERATOR
  MEMBER
}

model Poll {
  id            String     @id @default(cuid())
  postId        String     @unique
  question      String
  options       Json       @default("[]")
  endAt         DateTime?
  voterCount    Int        @default(0)
  allowMultiple Boolean    @default(false)
  createdAt     DateTime   @default(now())

  post          Post       @relation(fields: [postId], references: [id], onDelete: Cascade)
  votes         PollVote[]

  @@map("polls")
}

model PollVote {
  id          String   @id @default(cuid())
  pollId      String
  userId      String
  optionIndex Int
  createdAt   DateTime @default(now())

  poll        Poll     @relation(fields: [pollId], references: [id], onDelete: Cascade)

  @@unique([pollId, userId, optionIndex])
  @@index([pollId])
  @@map("poll_votes")
}

// ==================== ADS (QuantAds) ====================

model Campaign {
  id               String         @id @default(cuid())
  advertiserId     String
  name             String
  objective        CampaignObjective @default(AWARENESS)
  status           CampaignStatus @default(DRAFT)
  budget           Json           @default("{}")
  schedule         Json           @default("{}")
  targeting        Json           @default("{}")
  totalSpend       Float          @default(0)
  totalImpressions Int            @default(0)
  totalClicks      Int            @default(0)
  totalConversions Int            @default(0)
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  deletedAt        DateTime?

  advertiser       User           @relation(fields: [advertiserId], references: [id], onDelete: Cascade)
  adSets           AdSet[]

  @@index([advertiserId])
  @@index([status])
  @@map("campaigns")
}

enum CampaignObjective {
  AWARENESS
  TRAFFIC
  ENGAGEMENT
  LEADS
  CONVERSIONS
  APP_INSTALLS
}

enum CampaignStatus {
  DRAFT
  PENDING_REVIEW
  ACTIVE
  PAUSED
  COMPLETED
  REJECTED
}

model AdSet {
  id         String       @id @default(cuid())
  campaignId String
  name       String
  status     AdSetStatus  @default(DRAFT)
  budget     Json         @default("{}")
  targeting  Json         @default("{}")
  placement  Json         @default("[]")
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt

  campaign   Campaign     @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  ads        Ad[]

  @@index([campaignId])
  @@map("ad_sets")
}

enum AdSetStatus {
  DRAFT
  ACTIVE
  PAUSED
  COMPLETED
}

model Ad {
  id         String   @id @default(cuid())
  adSetId    String
  creativeId String
  name       String
  status     AdStatus @default(DRAFT)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  adSet      AdSet    @relation(fields: [adSetId], references: [id], onDelete: Cascade)
  creative   AdCreative @relation(fields: [creativeId], references: [id])

  @@index([adSetId])
  @@index([creativeId])
  @@map("ads")
}

enum AdStatus {
  DRAFT
  ACTIVE
  PAUSED
  REJECTED
}

model AdCreative {
  id           String          @id @default(cuid())
  advertiserId String
  type         AdCreativeType  @default(IMAGE)
  name         String
  headline     String?
  description  String?
  mediaUrl     String?
  callToAction String?
  landingUrl   String?
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt

  ads          Ad[]

  @@index([advertiserId])
  @@map("ad_creatives")
}

enum AdCreativeType {
  IMAGE
  VIDEO
  CAROUSEL
  COLLECTION
}

// ==================== MEDIA (QuantTube / QuantNeon) ====================

model Video {
  id               String             @id @default(cuid())
  userId           String
  channelId        String?
  title            String
  description      String?
  videoUrl         String
  thumbnailUrl     String?
  duration         Int                @default(0)
  width            Int?
  height           Int?
  fileSize         BigInt             @default(0)
  category         String?
  tags             Json               @default("[]")
  visibility       VideoVisibility    @default(PUBLIC)
  ageRestricted    Boolean            @default(false)
  viewCount        Int                @default(0)
  likeCount        Int                @default(0)
  commentCount     Int                @default(0)
  processingStatus VideoProcessingStatus @default(PENDING)
  publishedAt      DateTime?
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt
  deletedAt        DateTime?

  user             User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  channel          VideoChannel?      @relation(fields: [channelId], references: [id])

  @@index([userId])
  @@index([channelId])
  @@index([publishedAt])
  @@index([visibility])
  @@map("videos")
}

enum VideoVisibility {
  PUBLIC
  UNLISTED
  PRIVATE
}

enum VideoProcessingStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

model VideoChannel {
  id              String    @id @default(cuid())
  userId          String
  name            String
  handle          String    @unique
  description     String?
  avatarUrl       String?
  bannerUrl       String?
  subscriberCount Int       @default(0)
  videoCount      Int       @default(0)
  isVerified      Boolean   @default(false)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  videos          Video[]
  playlists       Playlist[]

  @@index([userId])
  @@index([handle])
  @@map("video_channels")
}

model Playlist {
  id          String       @id @default(cuid())
  userId      String
  channelId   String?
  title       String
  description String?
  visibility  VideoVisibility @default(PUBLIC)
  videoCount  Int          @default(0)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  channel     VideoChannel? @relation(fields: [channelId], references: [id])

  @@index([userId])
  @@index([channelId])
  @@map("playlists")
}

model Photo {
  id           String     @id @default(cuid())
  userId       String
  albumId      String?
  caption      String?
  imageUrl     String
  thumbnailUrl String?
  width        Int?
  height       Int?
  fileSize     Int        @default(0)
  filter       String?
  location     Json?
  tags         Json       @default("[]")
  likeCount    Int        @default(0)
  commentCount Int        @default(0)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  deletedAt    DateTime?

  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  album        PhotoAlbum? @relation(fields: [albumId], references: [id])

  @@index([userId])
  @@index([albumId])
  @@map("photos")
}

model PhotoAlbum {
  id           String          @id @default(cuid())
  userId       String
  name         String
  description  String?
  coverPhotoUrl String?
  photoCount   Int             @default(0)
  visibility   VideoVisibility @default(PUBLIC)
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt

  photos       Photo[]

  @@index([userId])
  @@map("photo_albums")
}

model Story {
  id           String    @id @default(cuid())
  userId       String
  type         StoryType @default(IMAGE)
  mediaUrl     String?
  thumbnailUrl String?
  duration     Int       @default(15)
  viewCount    Int       @default(0)
  expiresAt    DateTime
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@map("stories")
}

enum StoryType {
  IMAGE
  VIDEO
  TEXT
}

model Music {
  id         String   @id @default(cuid())
  title      String
  artistName String
  albumName  String?
  coverUrl   String?
  audioUrl   String
  duration   Int      @default(0)
  genre      String?
  playCount  Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([artistName])
  @@index([genre])
  @@map("music")
}

// ==================== PROFILES (QuantMax) ====================

model DatingProfile {
  id                 String             @id @default(cuid())
  userId             String             @unique
  displayName        String
  bio                String?
  age                Int
  gender             String?
  genderPreference   Json               @default("[]")
  location           Json?
  photos             Json               @default("[]")
  interests          Json               @default("[]")
  verificationStatus VerificationStatus @default(UNVERIFIED)
  isActive           Boolean            @default(true)
  profileScore       Float              @default(0)
  lastActive         DateTime?
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt

  user               User               @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([isActive])
  @@map("dating_profiles")
}

enum VerificationStatus {
  UNVERIFIED
  PENDING
  VERIFIED
  REJECTED
}

model Match {
  id             String   @id @default(cuid())
  user1Id        String
  user2Id        String
  matchedAt      DateTime @default(now())
  conversationId String?
  isActive       Boolean  @default(true)

  user1          User     @relation("MatchUser1", fields: [user1Id], references: [id], onDelete: Cascade)
  user2          User     @relation("MatchUser2", fields: [user2Id], references: [id], onDelete: Cascade)

  @@unique([user1Id, user2Id])
  @@index([user1Id])
  @@index([user2Id])
  @@map("matches")
}

model Swipe {
  id        String         @id @default(cuid())
  swiperId  String
  targetId  String
  direction SwipeDirection
  createdAt DateTime       @default(now())

  swiper    User           @relation("SwipeSwiper", fields: [swiperId], references: [id], onDelete: Cascade)
  target    User           @relation("SwipeTarget", fields: [targetId], references: [id], onDelete: Cascade)

  @@unique([swiperId, targetId])
  @@index([swiperId])
  @@index([targetId])
  @@map("swipes")
}

enum SwipeDirection {
  LEFT
  RIGHT
  SUPER_LIKE
}

model ShortVideo {
  id           String    @id @default(cuid())
  userId       String
  videoUrl     String
  thumbnailUrl String?
  caption      String?
  duration     Int       @default(0)
  soundId      String?
  hashtags     Json      @default("[]")
  viewCount    Int       @default(0)
  likeCount    Int       @default(0)
  shareCount   Int       @default(0)
  commentCount Int       @default(0)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  deletedAt    DateTime?

  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([createdAt])
  @@map("short_videos")
}

// ==================== AI (QuantAI) ====================

model AISession {
  id              String      @id @default(cuid())
  userId          String
  title           String?
  model           String      @default("gpt-4")
  systemPrompt    String?
  totalTokensUsed Int         @default(0)
  totalCost       Float       @default(0)
  tags            Json        @default("[]")
  isArchived      Boolean     @default(false)
  isPinned        Boolean     @default(false)
  sourceApp       String?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  deletedAt       DateTime?

  user            User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages        AIMessage[]

  @@index([userId])
  @@index([createdAt])
  @@map("ai_sessions")
}

model AIMessage {
  id           String        @id @default(cuid())
  sessionId    String
  role         AIMessageRole @default(USER)
  content      String
  attachments  Json          @default("[]")
  functionCall Json?
  tokenCount   Int           @default(0)
  model        String?
  latencyMs    Int?
  feedback     AIFeedback?
  createdAt    DateTime      @default(now())

  session      AISession     @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId])
  @@index([createdAt])
  @@map("ai_messages")
}

enum AIMessageRole {
  USER
  ASSISTANT
  SYSTEM
  FUNCTION
}

enum AIFeedback {
  POSITIVE
  NEGATIVE
}

// ==================== NOTIFICATIONS ====================

model Notification {
  id             String               @id @default(cuid())
  userId         String
  type           String
  title          String
  body           String?
  imageUrl       String?
  actionUrl      String?
  sourceApp      String?
  sourceUserId   String?
  sourceEntityId String?
  data           Json                 @default("{}")
  priority       NotificationPriority @default(NORMAL)
  isRead         Boolean              @default(false)
  readAt         DateTime?
  sentVia        Json                 @default("[]")
  expiresAt      DateTime?
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt

  user           User                 @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([isRead])
  @@index([createdAt])
  @@map("notifications")
}

enum NotificationPriority {
  LOW
  NORMAL
  HIGH
  URGENT
}

// ==================== DATA PLANE ====================

model OutboxEvent {
  id            String   @id @default(cuid())
  aggregateType String
  aggregateId   String
  eventType     String
  payload       Json
  createdAt     DateTime @default(now())
  publishedAt   DateTime?

  @@index([publishedAt])
  @@index([aggregateType, aggregateId])
  @@index([createdAt])
  @@map("outbox_events")
}

model AuditLog {
  id           String   @id @default(cuid())
  actorId      String
  action       String
  resourceType String
  resourceId   String
  diff         Json     @default("{}")
  ipAddress    String?
  userAgent    String?
  createdAt    DateTime @default(now())

  @@index([actorId])
  @@index([resourceType, resourceId])
  @@index([createdAt])
  @@map("audit_logs")
}

model EncryptionKey {
  id           String   @id @default(cuid())
  userId       String
  encryptedKey String
  algorithm    String   @default("AES-256-GCM")
  rotatedAt    DateTime?
  createdAt    DateTime @default(now())

  @@index([userId])
  @@map("encryption_keys")
}

// ==================== GIT HOSTING (QuantMail GitHub Killer) ====================

enum RepoVisibility {
  PUBLIC
  PRIVATE
  INTERNAL
}

enum PRStatus {
  OPEN
  MERGED
  CLOSED
  DRAFT
}

enum ReviewStatus {
  APPROVED
  CHANGES_REQUESTED
  COMMENTED
  PENDING
}

enum IssueStatus {
  OPEN
  CLOSED
}

enum MergeStrategy {
  MERGE
  SQUASH
  REBASE
}

enum CIStatus {
  PENDING
  RUNNING
  SUCCESS
  FAILED
  CANCELLED
}

model Repository {
  id             String         @id @default(cuid())
  ownerId        String
  name           String
  description    String?
  visibility     RepoVisibility @default(PUBLIC)
  defaultBranch  String         @default("main")
  storagePathUrl String?
  starCount      Int            @default(0)
  forkCount      Int            @default(0)
  isArchived     Boolean        @default(false)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  deletedAt      DateTime?

  owner              User               @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  branches           Branch[]
  pullRequests       PullRequest[]
  issues             Issue[]
  branchProtections  BranchProtection[]
  ciRuns             CIRun[]

  @@unique([ownerId, name])
  @@index([ownerId])
  @@index([visibility])
  @@index([createdAt])
  @@map("repositories")
}

model Branch {
  id          String   @id @default(cuid())
  repoId      String
  name        String
  commitSha   String
  isProtected Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  repository  Repository @relation(fields: [repoId], references: [id], onDelete: Cascade)

  @@unique([repoId, name])
  @@index([repoId])
  @@map("branches")
}

model PullRequest {
  id            String         @id @default(cuid())
  repoId        String
  number        Int
  title         String
  body          String?
  authorId      String
  status        PRStatus       @default(OPEN)
  sourceBranch  String
  targetBranch  String
  mergeStrategy MergeStrategy?
  mergedAt      DateTime?
  closedAt      DateTime?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  repository     Repository      @relation(fields: [repoId], references: [id], onDelete: Cascade)
  author         User            @relation(fields: [authorId], references: [id], onDelete: Cascade)
  reviews        Review[]
  reviewComments ReviewComment[]

  @@unique([repoId, number])
  @@index([repoId])
  @@index([authorId])
  @@index([status])
  @@map("pull_requests")
}

model Review {
  id         String       @id @default(cuid())
  prId       String
  reviewerId String
  status     ReviewStatus @default(PENDING)
  body       String?
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt

  pullRequest PullRequest @relation(fields: [prId], references: [id], onDelete: Cascade)
  reviewer    User        @relation(fields: [reviewerId], references: [id], onDelete: Cascade)

  @@index([prId])
  @@index([reviewerId])
  @@map("reviews")
}

model ReviewComment {
  id        String   @id @default(cuid())
  prId      String
  authorId  String
  filePath  String
  line      Int
  body      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  pullRequest PullRequest @relation(fields: [prId], references: [id], onDelete: Cascade)
  author      User        @relation(fields: [authorId], references: [id], onDelete: Cascade)

  @@index([prId])
  @@index([authorId])
  @@map("review_comments")
}

model Issue {
  id        String      @id @default(cuid())
  repoId    String
  number    Int
  title     String
  body      String?
  authorId  String
  status    IssueStatus @default(OPEN)
  labels    Json        @default("[]")
  assignees Json        @default("[]")
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt
  closedAt  DateTime?

  repository Repository @relation(fields: [repoId], references: [id], onDelete: Cascade)
  author     User       @relation(fields: [authorId], references: [id], onDelete: Cascade)

  @@unique([repoId, number])
  @@index([repoId])
  @@index([authorId])
  @@index([status])
  @@map("issues")
}

model BranchProtection {
  id                  String   @id @default(cuid())
  repoId              String
  branchPattern       String
  requiredApprovals   Int      @default(1)
  requireStatusChecks Boolean  @default(false)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  repository Repository @relation(fields: [repoId], references: [id], onDelete: Cascade)

  @@index([repoId])
  @@map("branch_protections")
}

model CIRun {
  id          String    @id @default(cuid())
  repoId      String
  prId        String?
  branch      String
  commitSha   String
  status      CIStatus  @default(PENDING)
  triggeredBy String?
  startedAt   DateTime?
  completedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  repository Repository @relation(fields: [repoId], references: [id], onDelete: Cascade)
  jobs       CIJob[]

  @@index([repoId])
  @@index([status])
  @@index([commitSha])
  @@map("ci_runs")
}

model CIJob {
  id          String    @id @default(cuid())
  runId       String
  name        String
  status      CIStatus  @default(PENDING)
  logs        String?
  artifacts   Json      @default("[]")
  startedAt   DateTime?
  completedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  run CIRun @relation(fields: [runId], references: [id], onDelete: Cascade)

  @@index([runId])
  @@index([status])
  @@map("ci_jobs")
}
