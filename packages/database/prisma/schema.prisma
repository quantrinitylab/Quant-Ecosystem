  conversationId String
  initiatorId    String
  type           CallType @default(VIDEO)
  status         CallStatus @default(RINGING)
  startedAt      DateTime?
  endedAt        DateTime?
  duration       Int?     // seconds
  participants   Json     @default("[]")
  roomId         String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([conversationId])
  @@index([initiatorId])
  @@index([createdAt])
  @@map("calls")
}

enum CallType {
  AUDIO
  VIDEO
}

enum CallStatus {
  RINGING
  ACTIVE
  ENDED
  MISSED
  DECLINED
}

model Media {
  id           String         @id @default(cuid())
  userId       String
  type         QuantMediaType
  url          String
  thumbnailUrl String?
  fileName     String?
  fileSize     Int?
  mimeType     String?
  width        Int?
  height       Int?
  duration     Int?
  createdAt    DateTime       @default(now())

  @@index([userId])
  @@index([type])
  @@index([createdAt])
  @@map("quantchat_media")
}

enum QuantMediaType {
  PHOTO
  VIDEO
  AUDIO
