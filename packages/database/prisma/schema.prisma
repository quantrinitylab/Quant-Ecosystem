/// A durable QuantEdits daily auto-edit run: select-source -> render -> meter ->
/// schedule/post -> report. `utcDay` is unique per user so a re-run for the same
/// day is idempotent (no double-post). Per-step checkpoints make an interrupted
/// run inspectable/resumable. Rendering + publishing go through pluggable ports
/// (NullRenderer fails closed until real WASM-ffmpeg is wired in staging).
model AutoEditRun {
  id             String    @id @default(cuid())
  userId         String
  utcDay         String
  status         String    @default("running") // running | completed | failed
  currentStep    Int       @default(0)
  checkpoints    Json      @default("[]")
  sourceRef      String?
  outputUrl      String?
  postId         String?
  creditsCharged Int       @default(0)
  error          String?
  startedAt      DateTime  @default(now())
  finishedAt     DateTime?

  @@unique([userId, utcDay])
  @@index([userId])
  @@map("auto_edit_runs")
}

/// A user's opt-in for the QuantEdits daily auto-edit -> auto-post loop (default
/// OFF). The daily scheduler only processes enabled users. Optional source /
/// template / caption defaults feed each run.
model AutoEditPreference {
  id         String   @id @default(cuid())
  userId     String   @unique
  enabled    Boolean  @default(false)
  sourceRef  String?
  templateId String?
  caption    String?
  createdAt  DateTime @default(now())
