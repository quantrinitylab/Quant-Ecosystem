{
  "name": "@quant/database",
  "version": "1.0.0",
  "private": true,
  "main": "src/index.ts",
  "types": "src/index.ts",
  "scripts": {
    "build": "prisma generate --schema=prisma/schema.prisma",
    "typecheck": "prisma generate --schema=prisma/schema.prisma && tsc --noEmit",
    "test": "vitest run",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:seed": "tsx src/seed.ts",
    "lint": "eslint ."
  },
  "dependencies": {
    "@prisma/client": "^6.19.3"
  },
  "devDependencies": {
    "@faker-js/faker": "^9.2.0",
    "prisma": "^6.19.3",
    "tsx": "^4.19.0"
  }
}
